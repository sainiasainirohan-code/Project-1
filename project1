class MainDashboard:
    def __init__(self, root):
        self.root = root
        self.root.title("Multi-App Suite Dashboard")
        self.root.geometry("1000x700")  # Resized gracefully for 7 side options
        self.root.resizable(False, False)
        
        # Style Definitions
        self.bg_sidebar = "#2C3E50"
        self.bg_active = "#1ABC9C"
        self.bg_content = "#ECF0F1"
        self.font_menu = ("Arial", 11, "bold")
        
        # Track active app & elements
        self.current_frame = None
        self.nav_buttons = {}
        self.game_running = False
        
        # Create Main Layout
        self.sidebar = tk.Frame(self.root, bg=self.bg_sidebar, width=220)
        self.sidebar.pack(side=tk.LEFT, fill=tk.Y)
        self.sidebar.pack_propagate(False)
        
        self.content_area = tk.Frame(self.root, bg=self.bg_content)
        self.content_area.pack(side=tk.RIGHT, fill=tk.BOTH, expand=True)
        
        self.build_sidebar()
        self.show_welcome_screen()

    def build_sidebar(self):
        title_lbl = tk.Label(self.sidebar, text="APPS MENU", font=("Arial", 16, "bold"), fg="white", bg=self.bg_sidebar, pady=20)
        title_lbl.pack()
        
        apps = [
            ("Secret Diary", self.load_diary_app),
            ("Retro Game", self.load_game_app),
            ("Calculator", self.load_calculator_app),
            ("Secure Vault", self.load_vault_app),
            ("Digital Clock", self.load_clock_app),
            ("Unit Converter", self.load_converter_app),  # 6th App Added
            ("Task Manager", self.load_tasks_app)        # 7th App Added
        ]
        
        for name, command in apps:
            btn = tk.Button(self.sidebar, text=name, font=self.font_menu, fg="white", bg=self.bg_sidebar, 
                            activebackground=self.bg_active, activeforeground="white", bd=0, height=2, 
                            command=command, anchor="w", padx=20)
            btn.pack(fill=tk.X, pady=2)
            self.nav_buttons[name] = btn

    def clear_content_area(self):
        self.game_running = False 
        if self.current_frame:
            self.current_frame.destroy()
        for name, btn in self.nav_buttons.items():
            btn.config(bg=self.bg_sidebar)

    def set_active_button(self, name):
        if name in self.nav_buttons:
            self.nav_buttons[name].config(bg=self.bg_active)

    def show_welcome_screen(self):
        self.clear_content_area()
        self.current_frame = tk.Frame(self.content_area, bg=self.bg_content)
        self.current_frame.pack(fill=tk.BOTH, expand=True)
        
        lbl = tk.Label(self.current_frame, text="Welcome to your Multi-App Suite", font=("Arial", 22, "bold"), bg=self.bg_content, fg="#34495E")
        lbl.pack(pady=180)
        lbl_sub = tk.Label(self.current_frame, text="Select an application from the sidebar to get started.", font=("Arial", 12), bg=self.bg_content, fg="#7F8C8D")
        lbl_sub.pack()

